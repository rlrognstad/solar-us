# Copy to .env and fill in. Get these by creating an app at https://developer-v4.enphase.com
ENPHASE_API_KEY=your_api_key
ENPHASE_CLIENT_ID=your_client_id
ENPHASE_CLIENT_SECRET=your_client_secret

# Must match the Redirect URI registered on your app. For a local/manual flow,
# the portal's out-of-band value works fine:
ENPHASE_REDIRECT_URI=https://api.enphaseenergy.com/oauth/redirect_uri

# Your system id. If you don't know it, run `solar-fetch systems` once after authorizing.
ENPHASE_SYSTEM_ID=

# Where to keep tokens and the data cache (defaults shown).
SOLAR_DATA_DIR=~/.local/share/solar
